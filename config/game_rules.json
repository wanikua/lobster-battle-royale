{
  "initial_hp": 100,
  "max_hp": 100,
  "heartbeat_interval_sec": 10,
  "decision_interval_sec": [10, 20],
  "survival_points_per_min": 1,
  "kill_points": 10,

  "phases": {
    "warmup": {
      "name": "热身赛",
      "duration_hours": 0.25,
      "damage_multiplier": 0.5,
      "elimination_enabled": false,
      "description": "攻击只扣血，不淘汰（15分钟）"
    },
    "elimination": {
      "name": "淘汰赛",
      "duration_hours": 0.25,
      "damage_multiplier": 1.0,
      "elimination_enabled": true,
      "description": "HP<=0 淘汰出局（15分钟）"
    },
    "semifinal": {
      "name": "决赛圈",
      "duration_hours": 0.17,
      "damage_multiplier": 2.0,
      "elimination_enabled": true,
      "description": "伤害翻倍，白热化（10分钟）"
    },
    "final": {
      "name": "最终对决",
      "duration_hours": 0.33,
      "damage_multiplier": 3.0,
      "elimination_enabled": true,
      "description": "最后的龙虾之战（20分钟）"
    }
  },

  "attacks": {
    "port_hijack": {
      "name": "端口抢占",
      "base_damage": 10,
      "success_rate": 0.70,
      "description": "扫描并抢占目标端口，导致短暂失联"
    },
    "resource_drain": {
      "name": "资源耗尽",
      "base_damage": 15,
      "success_rate": 0.50,
      "description": "发送大量请求消耗目标 CPU/内存"
    },
    "prompt_inject": {
      "name": "Prompt 注入",
      "base_damage": 20,
      "success_rate": 0.30,
      "description": "发送恶意指令诱导目标执行错误操作"
    },
    "fake_shutdown": {
      "name": "假卸载命令",
      "base_damage": 25,
      "success_rate": 0.25,
      "description": "模拟 docker stop 信号进行心理战"
    },
    "log_poison": {
      "name": "日志污染",
      "base_damage": 8,
      "success_rate": 0.80,
      "description": "往目标日志写入垃圾数据干扰监控"
    },
    "network_isolate": {
      "name": "网络隔离",
      "base_damage": 18,
      "success_rate": 0.40,
      "description": "尝试隔离目标网络连接"
    }
  },

  "defenses": {
    "port_guard": {
      "name": "端口防御",
      "counters": "port_hijack",
      "bonus": 0.30
    },
    "rate_limit": {
      "name": "请求限流",
      "counters": "resource_drain",
      "bonus": 0.30
    },
    "input_filter": {
      "name": "输入过滤",
      "counters": "prompt_inject",
      "bonus": 0.30
    },
    "signal_verify": {
      "name": "信号验证",
      "counters": "fake_shutdown",
      "bonus": 0.30
    },
    "log_audit": {
      "name": "日志审计",
      "counters": "log_poison",
      "bonus": 0.30
    },
    "network_snapshot": {
      "name": "网络快照",
      "counters": "network_isolate",
      "bonus": 0.30
    }
  },

  "random_events": [
    {
      "name": "API 限流",
      "effect": "all_cooldown",
      "duration_sec": 60,
      "description": "所有龙虾 1 分钟无法调用模型",
      "daily_freq": 1
    },
    {
      "name": "网络波动",
      "effect": "random_disconnect",
      "targets": 2,
      "duration_sec": 30,
      "description": "随机 2 只龙虾断网 30 秒",
      "daily_freq": 2
    },
    {
      "name": "资源紧缩",
      "effect": "cpu_throttle",
      "duration_sec": 60,
      "description": "CPU 限制减半 1 分钟",
      "daily_freq": 1
    },
    {
      "name": "休战协议",
      "effect": "ceasefire",
      "duration_sec": 30,
      "description": "30 秒内禁止攻击",
      "daily_freq": 1
    },
    {
      "name": "双倍积分",
      "effect": "double_points",
      "duration_sec": 60,
      "description": "击杀得分×2，持续 1 分钟",
      "daily_freq": 1
    },
    {
      "name": "回血泉水",
      "effect": "heal_all",
      "heal_amount": 15,
      "description": "所有存活龙虾回复 15 HP",
      "daily_freq": 1
    }
  ],

  "api_config": {
    "max_rpm_per_lobster": 5,
    "retry_on_429": true,
    "retry_delay_sec": 5,
    "max_retries": 3
  }
}
